# =============================================================================
# RENOVACIONES APP - ENVIRONMENT VARIABLES
# =============================================================================
# SECURITY WARNING: Never commit real credentials to git.
# Copy this file to .env and fill with your actual values.
# .env is already in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side service role key (NEVER expose to client/browser)
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co

# ---------------------------------------------------------------------------
# WhatsApp Notifications (CallMeBot - free tier available)
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
# ---------------------------------------------------------------------------
CALLMEBOT_API_KEY=your-callmebot-api-key

# ---------------------------------------------------------------------------
# Telegram Bot Notifications
# Create a bot with @BotFather: https://t.me/BotFather
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token

# ---------------------------------------------------------------------------
# Email Service (Resend - 100 emails/day free tier)
# https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key
