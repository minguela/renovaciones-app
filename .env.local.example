# Notification Service Credentials
# Copy this file to .env.local and fill in your credentials
# NEVER commit .env.local to git

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Twilio Test credentials (optional - for testing)
TWILIO_TEST_ACCOUNT_SID=
TWILIO_TEST_AUTH_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Email (Resend - 100 emails/day free)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev

# WhatsApp Business API (Meta)
# Get these from https://developers.facebook.com
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# Expo Push
# Get at https://expo.dev/accounts/[your-account]/settings/access-tokens
EXPO_ACCESS_TOKEN=your_expo_access_token_here

# Web Push VAPID keys
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:admin@renovaciones.app
